<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox onKeyPressed="#onKeyPressed" xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="it.garganovolpe.weendtray.ui.LoginPageController">
    <VBox alignment="CENTER" spacing="16">
        <VBox.margin>
            <Insets bottom="16" left="16" right="16" top="16" />
        </VBox.margin>
        <Text strokeType="OUTSIDE" strokeWidth="0.0"
            text="Benvenuto in WeendTray, accedi o registrati per continuare." />
        <TextField fx:id="username" promptText="Nome utente" />
        <PasswordField fx:id="passwordField" promptText="Password" />
        <CheckBox mnemonicParsing="false" text="Ricordami" fx:id="keepSession" />
        <HBox spacing="8">
            <Button maxWidth="Infinity" onAction="#onLogin" text="Accedi" HBox.hgrow="ALWAYS" />
            <Button maxWidth="Infinity" onAction="#onSignup" text="Registrati"
                HBox.hgrow="ALWAYS" />
        </HBox>
    </VBox>
</VBox>
