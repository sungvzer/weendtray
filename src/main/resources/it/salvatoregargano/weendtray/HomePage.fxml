<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>


<VBox xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="it.salvatoregargano.weendtray.ui.HomePageController">
    <ToolBar nodeOrientation="LEFT_TO_RIGHT" prefHeight="40.0" prefWidth="200.0">
        <Text fx:id="helloField" strokeType="OUTSIDE" strokeWidth="0.0" text="Text" />
        <Region prefHeight="0.0" HBox.hgrow="ALWAYS" />
        <Button mnemonicParsing="false" onAction="#onLogout" text="Esci" />
    </ToolBar>
    <TabPane fx:id="tabPane" prefHeight="200.0" prefWidth="200.0" tabClosingPolicy="UNAVAILABLE"
        VBox.vgrow="ALWAYS">
        <Tab fx:id="usersTab" closable="false" text="Utenti" />
        <Tab fx:id="userDashboardTab" closable="false" text="Dashboard" />
        <Tab fx:id="topUpTab" closable="false" text="Ricarica" />
        <Tab fx:id="internetTab" closable="false" text="Internet" />
    </TabPane>
</VBox>
