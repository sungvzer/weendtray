<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>
<VBox alignment="CENTER" spacing="16" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.salvatoregargano.weendtray.ui.HomePageController">
    <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Benvenuto in WeendTray, accedi o registrati per continuare."/>
    <VBox alignment="CENTER" spacing="16">
        <VBox.margin>
            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0"/>
        </VBox.margin>
        <TextField fx:id="emailField" promptText="Email"/>
        <PasswordField fx:id="passwordField" promptText="Password"/>
        <Button onMouseClicked="#onLogin" text="Login"/>
    </VBox>
</VBox>
