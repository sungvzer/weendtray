<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="500.0" prefWidth="500.0" spacing="10.0" xmlns="http://javafx.com/javafx/17.0.12"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="it.salvatoregargano.weendtray.ui.UserDashboardController">
    <children>

        <VBox spacing="5.0" style="-fx-border-color: #cccccc;">
            <children>
                <Label fx:id="userPhonePlan" text="Piano Tariffario Attivo:">
                    <font>
                        <Font size="11.0" />
                    </font>
                </Label>
                <Label fx:id="userPlanType" text="Conto: ">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>
                <Label fx:id="renewalLabel" text="Costo rinnovo:" />
                <Label fx:id="creditLabel" layoutX="21.0" layoutY="72.0" text="Credito residuo:" />
            </children>
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <VBox.margin>
                <Insets left="10.0" right="10.0" top="5.0" />
            </VBox.margin>
        </VBox>

        <VBox fx:id="usageBox" spacing="15.0">
            <children>

                <Label text="Consumi">
                    <VBox.margin>
                        <Insets top="5.0" />
                    </VBox.margin>
                </Label>
                <VBox>
                    <children>
                        <HBox>
                            <children>
                                <Label maxWidth="Infinity" prefHeight="17.0" prefWidth="392.0"
                                    text="Traffico Dati" HBox.hgrow="ALWAYS" />
                                <Label text="0" fx:id="userDataTraffic" />
                            </children>
                        </HBox>
                        <ProgressBar fx:id="dataProgress" maxWidth="Infinity" progress="0.0" />
                    </children>
                </VBox>

                <VBox>
                    <children>
                        <HBox>
                            <children>
                                <Label maxWidth="Infinity" text="Minuti" HBox.hgrow="ALWAYS" />
                                <Label text="0" fx:id="userCallMinutes" />
                            </children>
                        </HBox>
                        <ProgressBar fx:id="callProgress" maxWidth="Infinity" progress="0.0" />
                    </children>
                </VBox>

                <VBox>
                    <children>
                        <HBox>
                            <children>
                                <Label maxWidth="Infinity" text="SMS" HBox.hgrow="ALWAYS" />
                                <Label text="0" fx:id="userMessagesAmount" />
                            </children>
                        </HBox>
                        <ProgressBar fx:id="smsProgress" maxWidth="Infinity" progress="0.0" />
                    </children>
                </VBox>
            </children>
            <padding>
                <Insets left="15.0" right="15.0" />
            </padding>
        </VBox>

        <Separator prefWidth="200.0">
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </Separator>

        <HBox alignment="CENTER" spacing="10.0">
            <children>
                <Button fx:id="callBtn" mnemonicParsing="false" prefHeight="40.0" prefWidth="100.0"
                    text="Chiama" />
                <Button fx:id="smsBtn" mnemonicParsing="false" prefHeight="40.0" prefWidth="100.0"
                    text="SMS" />
                <Button onAction="#onInternet" mnemonicParsing="false" prefHeight="40.0"
                    prefWidth="100.0"
                    text="Internet" />
            </children>
            <padding>
                <Insets bottom="20.0" />
            </padding>
        </HBox>

    </children>
</VBox>
