<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="500.0" prefWidth="500.0" spacing="10.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.salvatoregargano.weendtray.ui.UserDashboardController">
    <children>

        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-border-color: #cccccc; -fx-border-width: 0 0 1 0;">
            <children>
                <VBox HBox.hgrow="ALWAYS">
                    <children>
                        <Label fx:id="userNameLabel" text="Mario Rossi">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Label>
                        <Label fx:id="phoneNumberLabel" text="333 1234567" />
                    </children>
                </VBox>
                <Button mnemonicParsing="false" text="Logout" />
            </children>
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
        </HBox>

        <VBox spacing="5.0" style="-fx-border-color: #cccccc;">
            <children>
                <Label text="Piano Tariffario Attivo:">
                    <font>
                        <Font size="11.0" />
                    </font>
                </Label>
                <Label fx:id="planNameLabel" text="Piano ">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>
                <Label fx:id="renewalLabel" text="Costo rinnovo:" />
            </children>
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <VBox.margin>
                <Insets left="10.0" right="10.0" top="5.0" />
            </VBox.margin>
        </VBox>

        <Label text="Consumi">
            <VBox.margin>
                <Insets left="10.0" top="5.0" />
            </VBox.margin>
        </Label>

        <VBox spacing="15.0">
            <children>
                <VBox>
                    <children>
                        <HBox>
                            <children>
                                <Label maxWidth="Infinity" text="Traffico Dati" HBox.hgrow="ALWAYS" />
                                <Label text="0" />
                            </children>
                        </HBox>
                        <ProgressBar fx:id="dataProgress" maxWidth="Infinity" progress="0.0" />
                    </children>
                </VBox>

                <VBox>
                    <children>
                        <HBox>
                            <children>
                                <Label maxWidth="Infinity" text="Minuti" HBox.hgrow="ALWAYS" />
                                <Label text="0" />
                            </children>
                        </HBox>
                        <ProgressBar fx:id="callProgress" maxWidth="Infinity" progress="0.0" />
                    </children>
                </VBox>

                <VBox>
                    <children>
                        <HBox>
                            <children>
                                <Label maxWidth="Infinity" text="SMS" HBox.hgrow="ALWAYS" />
                                <Label text="0" />
                            </children>
                        </HBox>
                        <ProgressBar fx:id="smsProgress" maxWidth="Infinity" progress="0.0" />
                    </children>
                </VBox>
            </children>
            <padding>
                <Insets left="15.0" right="15.0" />
            </padding>
        </VBox>

        <Separator prefWidth="200.0">
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </Separator>

        <HBox alignment="CENTER" spacing="10.0">
            <children>
                <Button fx:id="callBtn" mnemonicParsing="false" prefHeight="40.0" prefWidth="100.0" text="Chiama" />
                <Button fx:id="smsBtn" mnemonicParsing="false" prefHeight="40.0" prefWidth="100.0" text="Invia SMS" />
                <Button fx:id="dataBtn" mnemonicParsing="false" prefHeight="40.0" prefWidth="100.0" text="Usa Dati" />
            </children>
            <padding>
                <Insets bottom="20.0" />
            </padding>
        </HBox>

    </children>
</VBox>
