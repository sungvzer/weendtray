<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox spacing="8.0" VBox.vgrow="ALWAYS" xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="it.salvatoregargano.weendtray.ui.NewUserController">
    <HBox alignment="CENTER_LEFT" spacing="8.0">
        <TextField fx:id="usernameField" promptText="Nome utente" HBox.hgrow="ALWAYS" />
        <PasswordField fx:id="passwordField" promptText="Password" HBox.hgrow="ALWAYS" />
        <PasswordField fx:id="confirmPasswordField" promptText="Conferma Password"
            HBox.hgrow="ALWAYS" />
    </HBox>
    <HBox alignment="CENTER_LEFT" spacing="8.0">
        <children>
            <TextField fx:id="nameField" promptText="Nome" HBox.hgrow="ALWAYS" />
            <TextField fx:id="surnameField" promptText="Cognome" HBox.hgrow="ALWAYS" />
        </children>
    </HBox>
    <HBox alignment="CENTER_LEFT" spacing="8.0">
        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="+39" />
        <TextField fx:id="phoneNumberField" onKeyTyped="#handlePhoneNumberInput"
            promptText="Numero di telefono" HBox.hgrow="ALWAYS" />
        <ChoiceBox fx:id="phonePlanChoiceBox" prefWidth="150.0" HBox.hgrow="ALWAYS" />
    </HBox>
    <HBox alignment="CENTER_LEFT" spacing="8.0">
        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Indirizzo" />
    </HBox>
    <HBox alignment="CENTER_LEFT" spacing="8.0">
        <TextField fx:id="addressField" promptText="Via, numero civico" HBox.hgrow="ALWAYS" />
        <TextField fx:id="cityField" promptText="Città" HBox.hgrow="ALWAYS" />
        <TextField fx:id="stateField" promptText="Provincia" HBox.hgrow="ALWAYS" />
        <TextField fx:id="postalCodeField" promptText="CAP" HBox.hgrow="ALWAYS" />
        <TextField fx:id="countryField" promptText="Nazione" HBox.hgrow="ALWAYS" />
    </HBox>
    <Button mnemonicParsing="false" onAction="#handleSaveUser" text="Salva utente" />
    <opaqueInsets>
        <Insets />
    </opaqueInsets>
    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
    </padding>
</VBox>
