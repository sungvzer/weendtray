<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="8.0" VBox.vgrow="ALWAYS" xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="it.salvatoregargano.weendtray.ui.UsersTabController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <TextField fx:id="searchField" promptText="Cerca un utente" HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" text="Nuovo utente" onAction="#handleNewUser" />
        </HBox>
        <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" />
                <TableColumn fx:id="usernameColumn" text="Nome utente" />
                <TableColumn fx:id="nameColumn" text="Nome" />
                <TableColumn fx:id="surnameColumn" text="Cognome" />
                <TableColumn fx:id="phoneNumberColumn" text="Numero di telefono" />
                <TableColumn fx:id="phonePlanColumn" text="Tipo di piano" />
                <TableColumn fx:id="creditColumn" text="Credito residuo" />
                <TableColumn fx:id="actionsColumn" text="Azioni" />
            </columns>
        </TableView>
    </children>
    <padding>
        <Insets bottom="16.0" top="16.0" />
    </padding>
</VBox>
